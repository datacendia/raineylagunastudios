{
  "//": "Lighthouse CI configuration for raineylagunastudios. Audits the live",
  "//1": "deployed URL on every PR + push to main and asserts the budget below.",
  "//2": "Tighten thresholds in PRs that add genuine wins (image lazy-loading,",
  "//3": "font-display swap, etc.). Loosen only with a comment in the PR body.",
  "ci": {
    "collect": {
      "url": [
        "https://raineylagunastudios.com/",
        "https://raineylagunastudios.com/about/",
        "https://raineylagunastudios.com/relic/"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],

        "uses-responsive-images": "warn",
        "uses-text-compression": "error",
        "color-contrast": "error",
        "html-has-lang": "error",
        "meta-viewport": "error",
        "image-alt": "error",
        "robots-txt": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
